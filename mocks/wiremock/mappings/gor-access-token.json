{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/api/update-order-service/oauth/token",
    "headers": {
      "Authorization": {
        "matches": "Bearer .*"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    }
  },
  "response": {
    "status": 200,
    "bodyFileName": "gor-access-token-response.json",
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": ["response-template"]
  }
}
