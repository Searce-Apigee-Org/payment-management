{
  "request": {
    "method": "GET",
    "urlPath": "/v1/paymentManagement/payments",
    "queryParameters": {
      "mobileNumber": {
        "matches": ".+"
      }
    },
    "headers": {
      "authorization": {
        "matches": ".*"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "get-payments-v1.json"
  }
}
