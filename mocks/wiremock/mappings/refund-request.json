{
  "request": {
    "method": "POST",
    "urlPathPattern": "/v1/paymentManagement/payments/[^/]+/refund",
    "headers": {
      "authorization": { "matches": ".*" }
    },
    "bodyPatterns": [{ "matchesJsonPath": "$.refundAmount" }]
  },
  "response": {
    "status": 200,
    "bodyFileName": "refund-success-response.json",
    "headers": { "Content-Type": "application/json" }
  }
}
