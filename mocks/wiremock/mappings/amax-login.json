{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/webpartner-module/login/token",
    "bodyPatterns": [
      { "matchesJsonPath": "$.userName" },
      { "matchesJsonPath": "$.password" }
    ]
  },
  "response": {
    "status": 200,
    "bodyFileName": "amax-login-response.json",
    "headers": { "Content-Type": "application/json" }
  }
}
