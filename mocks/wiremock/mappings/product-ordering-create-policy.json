{
  "request": {
    "method": "POST",
    "urlPath": "/v1/productOrdering/internal/policy",
    "headers": { "Content-Type": { "equalTo": "application/json" } },
    "bodyPatterns": [
      { "matchesJsonPath": "$.tokenPaymentId" },
      { "matchesJsonPath": "$.successAmount" }
    ]
  },
  "response": {
    "status": 200,
    "bodyFileName": "product-ordering-create-policy-response.json",
    "headers": { "Content-Type": "application/json" }
  }
}
