{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/v1/paymentManagement/internal/csPayments",
    "headers": {
      "Content-Type": {
        "contains": "application/json"
      },
      "principalId": {
        "matches": ".*"
      }
    },
    "bodyPatterns": [
      { "matchesJsonPath": "$.tokenPaymentId" },
      { "matchesJsonPath": "$.paymentStatus" },
      { "matchesJsonPath": "$.transactionId" },
      { "matchesJsonPath": "$.paymentChannel" }
    ]
  },
  "response": {
    "status": 204,
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
