{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/api/update-order-service/order/paymentTokenId",
    "headers": {
      "Authorization": {
        "matches": "Bearer .*"
      },
      "ReferenceId": {
        "matches": ".*"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      { "matchesJsonPath": "$.paymentTokenId" },
      { "matchesJsonPath": "$.paymentStatus" },
      { "matchesJsonPath": "$.paymentChannel" }
    ]
  },
  "response": {
    "status": 204
  }
}
