sequenceDiagram
    title PaymentSessionCallback

    participant PS as Payment Service
    participant CXS
    participant DB as DynamoDB
    participant L as CXS API
    participant DNO as DNO/LF
    participant CAMEL

    PS->>CXS: Invoke Payment Session Callback
    activate CXS

    CXS->>CXS: Validate Request

    CXS->>DB: Get Payment (tokenPaymentId)
    activate DB
    DB-->>CXS: Payment Transaction
    deactivate DB

    note over CXS: Retrieve PartnerReferenceNumber from Payment Status Table

    alt PartnerReferenceNumber exists
        note over CXS,DB: Set isECPay = true
        CXS->>DB: Get ECPay Transaction (PartnerReferenceNumber)
        activate DB
        DB-->>CXS: ECPay Transaction
        deactivate DB

        CXS->>CXS: Validate Payment + ECPay Transactions
    end

    alt Notification Name = PaymentSessionCreated
        CXS->>CXS: Extract keys from tokenPaymentId

        alt Client = Globe Fiber Prepaid (GFP)
            CXS->>DNO: Invoke DNO/LF Payment Callback
        end
    end

    alt payload.checkoutUrl exists
        CXS->>DB: Update checkoutUrl
        activate DB
        DB-->>CXS: OK
        deactivate DB

        CXS->>DNO: update_payment
        activate DNO
        DNO-->>CXS: OK
        deactivate DNO

    else payload.paymentSession exists
        CXS->>DB: Update paymentSession
        activate DB
        DB-->>CXS: OK
        deactivate DB

    else payload.actions exists
        CXS->>DB: Update actions
        activate DB
        DB-->>CXS: OK
        deactivate DB

    else payload.error exists
        CXS->>DB: Save error details
        activate DB
        DB-->>CXS: OK
        deactivate DB

    else payload.refund exists
        CXS->>DB: Update status
        activate DB
        DB-->>CXS: OK
        deactivate DB

        CXS->>DNO: update_payment
        activate DNO
        DNO-->>CXS: OK
        deactivate DNO

    else payload.accounts exists
        CXS->>DB: Update status
        activate DB
        DB-->>CXS: OK
        deactivate DB

        alt Client = GlobeOnline
            CXS->>L: payment-status-callback
        else Client = Globe Prepaid Fiber
            CXS->>DNO: update_payment
            activate DNO
            DNO-->>CXS: OK
            deactivate DNO
        end
    end

    alt appStatus = SUCCESS AND paymentType = DROPIN
        CXS-->>PS: HTTP 200
    end

    alt appStatus = PROCESSING AND paymentType = DROPIN
        CXS->>DB: Update appStatus = SUCCESS
    end

    alt transactionType = G AND settlementDetails.notification exists AND paymentStatus = authorised
        CXS->>CAMEL: Send In-App Notification

    else (authorised OR CARD_AUTHORISED) AND appStatus = SUCCESS AND requestType = Buyload
        CXS->>L: buyload

    else (authorised OR CARD_AUTHORISED) AND appStatus = SUCCESS AND requestType = BuyPromo
        CXS->>L: purchasePromo

    else authorised AND requestType = BBPrepaidPromo
        CXS->>L: PrepaidFiberServiceOrders

    else authorised AND requestType = BBPrepaidRepair
        CXS->>L: PrepaidFiberRepairOrders

    else (authorised OR appStatus = SUCCESS) AND requestType = BuyVoucher
        CXS->>L: promoVoucher

    else (authorised OR appStatus = SUCCESS) AND isECPay = TRUE
        CXS->>DB: Put tokenPaymentId → ECPay Table
        activate DB
        DB-->>CXS: OK
        deactivate DB

        CXS->>L: ECPayProcessTransaction

    else (XENDIT_AUTHORISED OR GCASH_AUTHORISED) AND requestType = ChangeSim
        CXS->>L: ProcessCSPayment 

    else (XENDIT_AUTHORISED OR GCASH_AUTHORISED) AND budgetProtectEnabled = TRUE AND requestType = PayBills
        CXS->>L: CreatePolicy 

    else (authorised OR CARD_AUTHORISED) AND appStatus = SUCCESS AND requestType = BuyRoaming
        CXS->>L: ProvisionRoamingPromo

    else paymentStatus = refuse
        alt isECPay = TRUE
            note right of CXS: Store failure in ECPay & Payment Status tables
        end
        CXS->>DB: Update status
    end

    alt paymentStatus = authorised AND requestType in (BuyESIM, BuyESIMLocal, PtoESIM)
        CXS->>L: PaymentSendEmail (via Raven)
    end

    CXS-->>PS: HTTP 200
    deactivate CXS
