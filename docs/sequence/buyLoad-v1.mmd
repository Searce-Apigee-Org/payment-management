sequenceDiagram
    title BuyLoad-V1

    participant Consumer
    participant CXS
    participant SecretManager
    participant TokenStore
    participant AMAX
    participant MongoDB
    participant ProductOrdering
    participant OneAPI

    activate Consumer
    Consumer->>CXS: POST /v1/paymentManagement/topUp/{customerId}
    activate CXS

    CXS-->>Consumer: If not valid, return HTTP 400 (BadRequest)

    CXS->>CXS: pre-handler: setDefaultFields

    CXS->>CXS: msisdn = msisdnFormatter(customerId,'0')
    CXS->>CXS: channel = determineChannel(tokenPaymentId)\nchannelCode = extractChannelCode(tokenPaymentId)
    CXS->>CXS: Build transactionEntity\n{ tokenPaymentId, transactionId, amount,\n  keyword, wallet, mobileNumber,\n  status, channelCode, createdDate }

    CXS->>CXS: Extract tokenPrefix from tokenPaymentId

    CXS->>CXS: amaxService.executeAmaxTransaction(req, tokenPrefix, msisdn, amount, keyword, wallet)

    CXS->>SecretManager: getAmaxCredentials(tokenPrefix)
    SecretManager-->>CXS: credentials { userName, password, sourceWallet }

    CXS->>TokenStore: fetchSession(tokenPaymentId, AMAX)
    alt has valid cached session (isSessionValid)
        TokenStore-->>CXS: cached session (string or JSON)
        CXS->>CXS: reuse sessionId
    else no valid session
        TokenStore-->>CXS: null/expired
        CXS->>AMAX: login(credentials)
        AMAX-->>CXS: sessionId
        CXS->>TokenStore: updateSession(tokenPaymentId, JSON { sessionId, lastModifiedDate })
        TokenStore-->>CXS: OK
    end

    alt keyword is present (TopUp)
        CXS->>AMAX: topUp(sessionId, msisdn, amount, product=keyword)
        AMAX-->>CXS: transId
    else wallet path (Transfer)
        CXS->>AMAX: transfer(sessionId, credentials.sourceWallet, msisdn, wallet, amount)
        AMAX-->>CXS: transId
    end

    alt AMAX transaction succeeded (transId present)
        CXS->>CXS: transactionEntity.transactionId = transId
        par Success side-effects (Promise.all)
            CXS->>ProductOrdering: createPolicyAsync(req)
            ProductOrdering-->>CXS: OK
        and
            CXS->>ProductOrdering: addQuest(req)
            ProductOrdering-->>CXS: OK
        and
            CXS->>OneAPI: useVoucher(req)
            OneAPI-->>CXS: OK
        end

        CXS->>CXS: transactionEntity.status = SUCCESS
    else Error path (exception thrown)
        CXS->>CXS: log API_BUY_LOAD_ERROR
        CXS->>CXS: transactionEntity.status = FAILED

        note over CXS: refundService.handleRefundProcess(req, transactionEntity)
        alt tokenPaymentId contains SUPERAPP
            CXS->>MongoDB: find paymentEntity by tokenPaymentId
            MongoDB-->>CXS: paymentEntity
            CXS->>CXS: refundAmount = settlementDetails[0].amount\n+ budgetProtectProfile.chargeAmount(if present)
        else other channels
            CXS->>CXS: refundAmount = String(transactionEntity.amount)
        end
        CXS->>SecretManager: getRefundAuthToken()
        SecretManager-->>CXS: authToken
        CXS->>CXS: paymentManagementRepository.executeRefund({ refundAmount }, authToken)
        CXS-->>CXS: refundResponse (statusCode)
        alt refundResponse.statusCode == 202 AND paymentType != XENDIT
            note over CXS: Do not update PaymentEntity refund fields
        else
            CXS->>MongoDB: save PaymentEntity (update settlementDetails[].refund)
            MongoDB-->>CXS: saved
        end
    end

    par finally (Promise.all)
        CXS->>MongoDB: find paymentEntity by tokenPaymentId
        MongoDB-->>CXS: paymentEntity
        CXS->>CXS: userUuid = extractUserUuid(paymentEntity.userToken)
        CXS->>CXS: paymentService.updateOnBuyLoad(req, status, transactionId)
        CXS->>MongoDB: save PaymentEntity
        MongoDB-->>CXS: saved
    and
        CXS->>MongoDB: save BuyLoadTransactions (transactionEntity, userUuid)
        MongoDB-->>CXS: saved
    end

    CXS-->>Consumer: Return HTTP 201
    deactivate CXS
    deactivate Consumer
