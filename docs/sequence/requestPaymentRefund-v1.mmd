sequenceDiagram
    participant Consumer
    participant CXS
    participant PaymentRefundHelper
    participant SecretManager
    participant PaymentService
    participant DB(Mongo)

    Consumer->>CXS: Invoke "requestPaymentRefund" (tokenPaymentId, payload, headers)
    CXS->>CXS: Set event_name = "RequestPaymentRefund" in DataDictionary

    CXS->>PaymentRefundHelper: findPaymentSessionDetails(tokenPaymentId, mongo)
    PaymentRefundHelper->>DB(Mongo): Query payment session by tokenPaymentId
    DB(Mongo)-->>PaymentRefundHelper: Return paymentSessionInfo
    PaymentRefundHelper-->>CXS: Return paymentSessionInfo

    CXS->>PaymentRefundHelper: retrievePaymentServiceAccessToken(req, channelId)
    alt If access token is cached
        PaymentRefundHelper-->>CXS: Return cached accessToken
    else
        PaymentRefundHelper->>SecretManager: Get accessToken from Secret Manager
        SecretManager-->>PaymentRefundHelper: Return accessToken
        PaymentRefundHelper-->>CXS: Return accessToken
    end

    CXS->>CXS: Build refund requestBody (Xendit or default)
    CXS->>PaymentService: requestRefundByTokenId(http, requestBody, header)
    PaymentService-->>CXS: Return result

    alt If paymentSessionInfo.deviceId exists
        CXS->>CXS: Set headers.deviceid = paymentSessionInfo.deviceId
    end

    CXS->>CXS: Update DataDictionary with channel, event_detail

    alt If result.status != 200
        CXS->>CXS: Log error
        CXS-->>Consumer: Throw error (InternalOperationFailed)
    else
        CXS->>CXS: Set transaction_status = SUCCESS in DataDictionary
        CXS-->>Consumer: Return { statusCode: 202 }
    end

    alt If exception occurs
        CXS->>CXS: Log error
        CXS-->>Consumer: Throw error
    end
