sequenceDiagram
    title GetPaymentReceipt

    participant Consumer
    participant CXS
    participant SecretMgr as Secret Manager
    participant Rudy

    Consumer->>CXS: Invoke GetPaymentReceipt<br/>Headers: x-receipt-token, user-token<br/>Query: appCode, storeId
    activate Consumer
    activate CXS

    CXS->>CXS: Validate Request & Extract Tokens

    CXS->>SecretMgr: Get Auth Credentials for Rudy
    SecretMgr-->>CXS: Return Auth Credentials

    CXS->>SecretMgr: Get Payment Credentials (Token Secret)
    SecretMgr-->>CXS: Return Token Secret

    CXS->>CXS: Verify x-receipt-token (JWT)
    alt Token invalid or expired
        CXS-->>Consumer: Error: InvalidToken / ExpiredAccessToken
    else Token valid
        CXS->>CXS: Verify user-token matches decoded token (if provided)
        alt user-token mismatch
            CXS-->>Consumer: Error: MismatchedUserToken
        else OTP validation
            CXS->>CXS: Set OTP mobile number in request
            CXS->>CXS: checkThenValidate OTP

            CXS->>Rudy: getReceiptUrl(receiptId, storeId, appCode, auth)
            Rudy-->>CXS: Return receiptUrl

            CXS->>Rudy: getReceiptBody(receiptUrl, auth)
            Rudy-->>CXS: Return receiptBody

            alt Receipt not found
                CXS-->>Consumer: Error: ResourceNotFound
            else Receipt found
                CXS-->>Consumer: Return receiptBody (text/html)
            end
        end
    end

    deactivate CXS
    deactivate Consumer
