{
  "microservice": {
    "identifier": "payment-management",
    "displayName": "payment-management",
    "description": "payment-management",
    "baseURL": "subdomain.domain.com",
    "team": "cxs",
    "status": "LIVE",
    "versions": [
      {
        "displayName": "payment-management-v1",
        "identifier": "payment-management-v1",
        "changeLogDescription": "payment-management-v1",
        "specification": {
          "identifier": "payment-management-v1",
          "displayName": "payment-management-v1",
          "filePath": "docs/swagger.yaml"
        }
      }
    ],
    "endpoints": [
      {
        "displayName": "CreateESIMPaymentSession-V1",
        "identifier": "create-esim-payment-session-v1",
        "path": "/v1/paymentManagement/esim/payments/session",
        "method": "POST",
        "description": "Fetches payment session token and returns it.",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/createEsimPaymentSession-v1.mmd"
      },
      {
        "displayName": "GetPaymentReceipt-V1",
        "identifier": "get-payment-receipt-v1",
        "path": "/v1/paymentManagement/receipts/{receiptId}",
        "method": "GET",
        "description": "Retrieves receipt for a given payment transaction",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/getPaymentReceipt-v1.mmd"
      },
      {
        "displayName": "GetPaymentSessionByTokenPaymentId-V1",
        "identifier": "get-payment-session-v1",
        "path": "/v1/paymentManagement/payments/{tokenPaymentId}/sessions",
        "method": "GET",
        "description": "Fetches payment session using token payment id.",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/getPaymentSession-v1.mmd"
      },
      {
        "displayName": "GetPayments-V1",
        "identifier": "get-payments-v1",
        "path": "/v1/paymentManagement/payments",
        "method": "GET",
        "description": "To retrieve account payment history using GetAccountPaymentHistory API of EOR via CXS",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/getPayments-v1.mmd"
      },
      {
        "displayName": "CreatePaymentSession-V1",
        "identifier": "create-payment-session-v1",
        "path": "/v1/paymentManagement/payments/sessions",
        "method": "POST",
        "description": "Requests payment session token from Payment Service and sends the session token as response.",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/createPaymentSession-v1.mmd"
      },
      {
        "displayName": "PaymentSessionCallback-V1",
        "identifier": "payment-session-callback-v1",
        "path": "/v1/paymentManagement/payments/sessions/callback",
        "method": "POST",
        "description": "An API for receiving payment session data from Payment Service",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/paymentSessionCallback-v1.mmd"
      },
      {
        "displayName": "ProcessCSPayments-V1",
        "identifier": "process-cs-payments-v1",
        "path": "/v1/paymentManagement/internal/csPayments",
        "method": "POST",
        "description": "To update the payment status of a change sim transaction",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/processCSPayments-v1.mmd"
      },
      {
        "displayName": "RequestPaymentRefundRoutes-V1",
        "identifier": "request-payment-refund-v1",
        "path": "v1/paymentManagement/payments/{tokenPaymentId}/refund",
        "method": "POST",
        "description": "This API will call Refund API directly from PayO to process GCash refund.",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/requestPaymentRefund-v1.mmd"
      },
      {
        "displayName": "BuyLoad-V1",
        "identifier": "buy-load-v1",
        "path": "/v1/paymentManagement/topUp/{customerId}",
        "method": "POST",
        "description": "To allow users to buy retailer/consumer load.",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/buyLoad-v1.mmd"
      },
      {
        "displayName": "CreateWebPaymentSession-V2",
        "identifier": "create-web-payment-session-v2",
        "path": "/v2/paymentManagement/payments/websessions",
        "method": "POST",
        "description": "Creates a web payment session in GPayO T2",
        "status": "LIVE",
        "sequenceFilePath": "docs/sequence/createWebPaymentSession-v2.mmd"
      }
    ]
  }
}
